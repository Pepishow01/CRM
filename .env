# Base de datos
POSTGRES_USER=crm
POSTGRES_PASSWORD=crm_secret
POSTGRES_DB=crm_db
DATABASE_URL=postgresql://crm:crm_secret@localhost:5432/crm_db

# Redis
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379

# JWT - claves secretas para los tokens de login
JWT_SECRET=development_jwt_secret_cambiar_en_produccion
JWT_REFRESH_SECRET=development_refresh_secret_cambiar_en_produccion

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Meta / WhatsApp (completar después cuando configures Meta)
META_WEBHOOK_VERIFY_TOKEN=mi_token_secreto_webhook
META_APP_SECRET=completar_despues
WHATSAPP_API_TOKEN=completar_despues
WHATSAPP_PHONE_NUMBER_ID=completar_despues
META_API_VERSION=v19.0

# IA (completar después cuando tengas la API key de Anthropic)
ANTHROPIC_API_KEY=completar_despues
AI_ENABLED=false
AI_MODEL=claude-sonnet-4-5